{
  "expo": {
    "name": "Bloom",
    "slug": "bloom",
    "version": "1.0.0",
    "scheme": "bloom",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#F4EFE6"
    },
    "android": {
      "package": "com.bloom.app",
      "edgeToEdgeEnabled": true
    },
    "ios": {
      "bundleIdentifier": "com.bloom.app",
      "supportsTablet": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Bloom needs access to your photos to analyze your space."
        }
      ]
    ]
  }
}

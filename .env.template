# Get a key at https://openrouter.ai/keys
# Copy this file to .env and paste your key below.
# Without a key, the app runs in demo mode (mock picks, no AI composites).

EXPO_PUBLIC_OPENROUTER_KEY=your_openrouter_api_key_here

